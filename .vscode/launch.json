    "configurations": [
        {
            "name": "nbcoder",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/backend/cmd/server",
            "cwd": "${workspaceFolder}/work",
            "substitutePath": [
                {
                    "from": "${workspaceFolder}", // 编译路径 (容器内)
